quant.danielmtzbarba.com {
    # 1. THE HEALTH BRIDGE: For external status checks
    handle /health* {
        reverse_proxy messaging_service:8003
    }

    # 2. THE WEBHOOK DOOR: Pure Handshake (Meta API)
    # Match both /webhook and /api/webhook using a named matcher
    @webhooks {
        path /webhook* /api/webhook*
    }
    handle @webhooks {
        # Strip /api prefix if provided (does nothing if prefix doesn't match)
        uri strip_prefix /api
        reverse_proxy messaging_service:8003

        # STRIP ALL BROWSER HEADERS (Meta's bot requires raw text/no noise)
        header {
            -Permissions-Policy
            -Strict-Transport-Security
            -X-Content-Type-Options
            -X-Frame-Options
        }
    }

    # 3. THE CHASM: Drop everything else
    handle {
        abort
    }
}
