quant.danielmtzbarba.com {
    # 1. THE WEBHOOK DOOR: Pure Handshake (Meta API)
    # Match both /webhook and /webhook/ to prevent 307 redirects
    handle /webhook* {
        reverse_proxy messaging-service:8003
        
        # STRIP ALL BROWSER HEADERS (Meta's bot requires raw text/no noise)
        header {
            -Permissions-Policy
            -Strict-Transport-Security
            -X-Content-Type-Options
            -X-Frame-Options
        }
    }

    # 2. THE CHASM: Drop everything else
    handle {
        abort
    }

    # Enable logging for auditing traffic flows
    log {
        output file /data/access.log
    }
}
