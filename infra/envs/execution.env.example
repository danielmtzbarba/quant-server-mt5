# -----------------------------------------------------------------------------
# EXECUTION.ENV.EXAMPLE
# -----------------------------------------------------------------------------
# Execution service (TradeDB & MT5 Interface) configuration.

# InfluxDB Connection (Time-series data)
# MODE A: Standard (Bundled Docker DB)
# INFLUX_URL=http://host.docker.internal:8086

# MODE B: Hybrid (GCP VM -> Local PC DB via Tailscale)
# Replace '100.x.y.z' with your Local PC's Tailscale IP.
INFLUX_URL=http://100.x.y.z:8086

INFLUX_TOKEN=your_influxdb_token
INFLUX_ORG=danielmtz
INFLUX_BUCKET=tradedb
