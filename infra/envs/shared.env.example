# -----------------------------------------------------------------------------
# SHARED.ENV.EXAMPLE
# -----------------------------------------------------------------------------
# Core database settings used by multiple services.

# SQLAlchemy database URL
# MODE A: Standard (Bundled Docker DB)
# DATABASE_URL=postgresql+asyncpg://danielmtz:your_secure_password@host.docker.internal:5432/tradedb

# MODE B: Hybrid (GCP VM -> Local PC DB via Tailscale)
# **SECURITY**: Use a strong password and ensure local pg_hba.conf is restricted.
# Replace '100.x.y.z' with your Local PC's Tailscale IP.
DATABASE_URL=postgresql+asyncpg://danielmtz:your_secure_password@100.x.y.z:5432/tradedb

# PostgreSQL Instance Initialization (Database containers only)
POSTGRES_DB=tradedb
POSTGRES_USER=danielmtz
POSTGRES_PASSWORD=your_secure_password
POSTGRES_PORT=5432
