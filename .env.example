# -----------------------------------------------------------------------------
# ROOT .ENV EXAMPLE
# -----------------------------------------------------------------------------
# Use this for local development. Copy to .env and fill in the values.

# Service Discovery (Internal Docker Network)
CORE_SERVICE_URL=http://core_service:8001
EXECUTION_SERVICE_URL=http://execution_service:8002
MESSAGING_SERVICE_URL=http://messaging_service:8003

# Database (PostgreSQL)
POSTGRES_DB=tradedb
POSTGRES_USER=danielmtz
POSTGRES_PASSWORD=your_secure_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@host.docker.internal:5432/${POSTGRES_DB}

# Time-Series (InfluxDB)
INFLUX_URL=http://host.docker.internal:8086
INFLUX_TOKEN=your_influx_token
INFLUX_ORG=danielmtz
INFLUX_BUCKET=tradedb

# WhatsApp API
WHATSAPP_API_TOKEN=your_meta_app_token
WHATSAPP_AUTH_TOKEN=your_verification_token
WHATSAPP_URL=https://graph.facebook.com/v17.0/your_phone_id/messages

# Application Settings
APP_URL=https://your-ngrok-or-domain.dev
ADMIN_TOKEN=your_admin_secret

# LLM Settings (OpenAI Only)
LLM_PROVIDER=OPENAI
OPENAI_API_KEY=sk-proj-your_openai_key
